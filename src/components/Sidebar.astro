---
import Icon from "./Icon.astro";
import profile from "../data/profile.json";
---

<aside
  class="flex flex-col gap-4 p-6 lg:sticky lg:top-0 lg:overflow-y-auto lg:p-8"
>
  <div class="flex flex-1 flex-col rounded-3xl border border-line bg-panel p-6">
    <div class="flex items-start justify-between gap-3">
      <div class="flex items-center gap-2">
        <span class="text-lg font-semibold text-ink">{profile.name}</span>
      </div>
      <p class="max-w-32 text-right text-sm leading-snug text-muted">
        {profile.role}
      </p>
    </div>

    <div class="mt-6 overflow-hidden rounded-2xl bg-panel-2">
      <img
        src={profile.avatar}
        alt={profile.name}
        class="aspect-square w-full object-cover grayscale"
        loading="lazy"
      />
    </div>

    <div class="mt-6 space-y-1 text-center text-sm">
      <p class="text-ink">{profile.email}</p>
      <p class="text-muted">{profile.location}</p>
    </div>

    <p class="mt-6 text-center text-xs text-faint">{profile.copyright}</p>

    <div class="mt-6 flex items-center justify-center gap-3">
      {
        profile.social.map((s) => (
          <a
            href={s.href}
            aria-label={s.label}
            class="flex h-9 w-9 items-center justify-center rounded-full border border-line text-muted transition hover:border-accent hover:text-accent"
          >
            <Icon name={s.icon as any} class="h-4 w-4" />
          </a>
        ))
      }
    </div>

    <a
      href={profile.hireMeHref}
      class="mt-6 flex items-center justify-center gap-2 rounded-full bg-accent px-6 py-3 text-sm font-semibold text-accent-ink transition hover:opacity-90"
    >
      <Icon name="mail" class="h-4 w-4" />
      {profile.hireMeLabel}
    </a>
  </div>
</aside>
