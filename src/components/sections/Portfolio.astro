---
import SectionHeading from '../SectionHeading.astro';
import portfolio from '../../data/portfolio.json';
---

<section id={portfolio.id} class="border-b border-line px-8 py-20 sm:px-12">
	<SectionHeading tag={portfolio.tag} icon={portfolio.icon} heading={portfolio.heading} />

	<div class="mt-10 grid gap-6 sm:grid-cols-2">
		{
			portfolio.projects.map((project, i) => (
				<a
					href="#"
					class="group block overflow-hidden rounded-2xl border border-line bg-panel"
					data-aos="fade-up"
					data-aos-delay={i * 100}
				>
					<div class="aspect-4/3 overflow-hidden">
						<img
							src={project.image}
							alt={project.title}
							loading="lazy"
							class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
						/>
					</div>
					<div class="p-5">
						<div class="flex flex-wrap gap-2">
							{project.tech.map((tech) => (
								<span class="rounded-full border border-line px-3 py-1 text-xs text-muted">{tech}</span>
							))}
						</div>
						<p class="mt-3 font-medium text-ink">{project.title}</p>
						<p class="mt-2 text-sm leading-relaxed text-muted">{project.description}</p>
						<p class="mt-3 text-xs uppercase tracking-wide text-faint">{project.role}</p>
					</div>
				</a>
			))
		}
	</div>
</section>
