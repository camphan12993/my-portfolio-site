---
import Icon from './Icon.astro';
import profile from '../data/profile.json';
---

<footer class="px-8 py-10 sm:px-12">
	<div class="flex flex-col items-center gap-4 text-center sm:flex-row sm:justify-between sm:text-left">
		<p class="text-sm text-faint">{profile.copyright}</p>
		<div class="flex items-center gap-3">
			{
				profile.social.map((s) => (
					<a
						href={s.href}
						aria-label={s.label}
						class="flex h-9 w-9 items-center justify-center rounded-full border border-line text-muted transition hover:border-accent hover:text-accent"
					>
						<Icon name={s.icon as any} class="h-4 w-4" />
					</a>
				))
			}
		</div>
	</div>
</footer>
