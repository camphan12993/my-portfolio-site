---
import SectionHeading from '../SectionHeading.astro';
import Icon from '../Icon.astro';
import certificates from '../../data/certificates.json';
---

<section id={certificates.id} class="border-b border-line px-8 py-20 sm:px-12">
	<SectionHeading tag={certificates.tag} icon={certificates.icon} heading={certificates.heading} />

	<div class="mt-10 grid gap-6 sm:grid-cols-2">
		{
			certificates.items.map((item, i) => {
				const Tag = item.url ? 'a' : 'div';
				return (
					<Tag
						href={item.url || undefined}
						target={item.url ? '_blank' : undefined}
						rel={item.url ? 'noreferrer' : undefined}
						class="group flex items-center gap-5 rounded-2xl border border-line bg-panel p-8 transition hover:border-accent/50"
						data-aos="fade-up"
						data-aos-delay={i * 80}
					>
						<div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full border border-line bg-panel-2 text-accent transition duration-300 group-hover:scale-105">
							<Icon name={item.url ? 'external-link' : 'award'} class="h-8 w-8" />
						</div>
						<div class="min-w-0">
							<p class="text-xl font-semibold text-ink">{item.name}</p>
							<p class="mt-1 text-base text-muted">{item.issuer}</p>
						</div>
					</Tag>
				);
			})
		}
	</div>
</section>
