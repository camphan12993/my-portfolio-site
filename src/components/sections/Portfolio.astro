---
import SectionHeading from "../SectionHeading.astro";
import Icon from "../Icon.astro";
import portfolio from "../../data/portfolio.json";
---

<section id={portfolio.id} class="border-b border-line px-8 py-20 sm:px-12">
  <SectionHeading
    tag={portfolio.tag}
    icon={portfolio.icon}
    heading={portfolio.heading}
  />

  <div class="mt-10 grid gap-6 sm:grid-cols-2">
    {
      portfolio.projects.map((project, i) => (
        <div
          class="group block overflow-hidden rounded-2xl border border-line bg-panel p-5"
          data-aos="fade-up"
          data-aos-delay={i * 100}
        >
          <div class="flex items-start gap-4">
            <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-xl border border-line bg-panel-2 text-accent transition duration-300 group-hover:scale-105">
              <Icon name={project.icon as any} class="h-7 w-7" />
            </div>
            <div class="min-w-0">
              <p class="text-lg font-semibold text-ink">{project.title}</p>
              <p class="mt-1 text-sm uppercase tracking-wide text-faint">
                {project.role}
              </p>
              <p class="mt-1 flex items-center gap-1.5 text-sm text-faint">
                <Icon name="users" class="h-4 w-4" />
                {project.team}
              </p>
            </div>
          </div>
          <p class="mt-4 text-base leading-relaxed text-muted">
            {project.description}
          </p>
          <div class="mt-4 border-t border-line pt-3">
            <p class="text-sm font-semibold uppercase tracking-wide text-white">
              Tech
            </p>
            <div class="mt-2 flex flex-wrap gap-2">
              {project.tech.map((tech) => (
                <span class="rounded-full border border-line px-3 py-1 text-sm text-muted">
                  {tech}
                </span>
              ))}
            </div>
          </div>
          <div class="mt-3 pt-3">
            <p class="text-sm font-semibold uppercase tracking-wide text-white">
              Role
            </p>
            <p class="mt-2 text-sm leading-relaxed text-muted">
              {project.roleDescription}
            </p>
          </div>
        </div>
      ))
    }
  </div>
</section>
