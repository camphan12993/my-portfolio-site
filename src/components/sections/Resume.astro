---
import SectionHeading from '../SectionHeading.astro';
import resume from '../../data/resume.json';
---

<section id={resume.id} class="border-b border-line px-8 py-20 sm:px-12">
	<SectionHeading tag={resume.tag} icon={resume.icon} heading={resume.heading} />

	<ol class="mt-10 space-y-10 border-l border-line pl-8">
		{
			resume.timeline.map((entry, i) => (
				<li class="relative" data-aos="fade-up" data-aos-delay={i * 100}>
					<span class="absolute -left-[calc(2rem+5px)] top-1.5 h-2.5 w-2.5 rounded-full bg-accent" />
					<p class="text-xs uppercase tracking-wide text-faint">{entry.period} - {entry.org}</p>
					<ul class="mt-3 space-y-1">
						{entry.roles.map((role) => (
							<li class="font-medium text-ink">{role}</li>
						))}
					</ul>
					<p class="mt-2 text-sm leading-relaxed text-muted">{entry.description}</p>
				</li>
			))
		}
	</ol>
</section>
