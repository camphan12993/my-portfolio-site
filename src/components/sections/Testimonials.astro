---
import SectionHeading from '../SectionHeading.astro';
import testimonials from '../../data/testimonials.json';
---

<section id={testimonials.id} class="border-b border-line px-8 py-20 sm:px-12">
	<SectionHeading tag={testimonials.tag} icon={testimonials.icon} heading={testimonials.heading} />

	<div class="mt-10 space-y-4">
		{
			testimonials.items.map((item, i) => (
				<div class="rounded-2xl border border-line bg-panel p-6" data-aos="fade-up" data-aos-delay={i * 100}>
					<p class="text-muted">&ldquo;{item.quote}&rdquo;</p>
					<div class="mt-6 flex items-center gap-3">
						<img src={item.avatar} alt={item.name} class="h-10 w-10 rounded-full object-cover" loading="lazy" />
						<div>
							<p class="text-sm font-medium text-ink">{item.name}</p>
							<p class="text-xs text-faint">{item.role}</p>
						</div>
					</div>
				</div>
			))
		}
	</div>
</section>
