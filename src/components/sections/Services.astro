---
import SectionHeading from '../SectionHeading.astro';
import Icon from '../Icon.astro';
import services from '../../data/services.json';
---

<section id={services.id} class="border-b border-line px-8 py-20 sm:px-12">
	<SectionHeading tag={services.tag} icon={services.icon} heading={services.heading} />

	<div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
		{
			services.items.map((item) => (
				<div class="flex items-center justify-between rounded-2xl border border-line bg-panel p-6">
					<div>
						<p class="font-medium text-ink">{item.title}</p>
						<p class="mt-1 text-xs text-faint">{item.meta}</p>
					</div>
					<Icon name={item.icon as any} class="h-5 w-5 text-accent" />
				</div>
			))
		}
	</div>
</section>
