---
import SectionHeading from '../SectionHeading.astro';
import about from '../../data/about.json';
---

<section id={about.id} class="border-b border-line px-8 py-20 sm:px-12">
	<SectionHeading tag={about.tag} icon={about.icon} heading={about.heading} />
	<p class="mt-6 max-w-2xl text-muted" data-aos="fade-up" data-aos-delay="120">{about.paragraph}</p>
</section>
