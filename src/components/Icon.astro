---
import { Icon as AstroIcon } from 'astro-icon/components';

// Friendly names used across the site, mapped to the Lucide icon set (via astro-icon).
const iconMap = {
	settings: 'lucide:settings',
	menu: 'lucide:menu',
	home: 'lucide:house',
	user: 'lucide:user',
	briefcase: 'lucide:briefcase',
	list: 'lucide:list',
	hexagon: 'lucide:hexagon',
	grid: 'lucide:layout-grid',
	'message-circle': 'lucide:message-circle',
	mail: 'lucide:mail',
	'arrow-down': 'lucide:arrow-down',
	twitter: 'lucide:twitter',
	instagram: 'lucide:instagram',
	github: 'lucide:github',
	dribbble: 'lucide:dribbble',
	'chevron-left': 'lucide:chevron-left',
	'chevron-right': 'lucide:chevron-right',
} as const;

interface Props {
	name: keyof typeof iconMap;
	class?: string;
}

const { name, class: className = 'h-5 w-5' } = Astro.props;
---

<AstroIcon name={iconMap[name]} class={className} />
